<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0F6B5C">
  <title>{{ title }} · {{ site.siteName }} Admin</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/assets/css/theme.css" rel="stylesheet">
</head>
<body class="admin-body">

  <header class="app-topbar">
    <button class="icon-btn d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminSidebarOffcanvas" aria-label="Open menu">
      <i class="bi bi-list"></i>
    </button>
    <span class="brand"><span class="brand-dot"></span> {{ title }}</span>
  </header>

  <div class="admin-shell">
    <!-- Desktop sidebar -->
    <aside class="admin-sidebar d-none d-lg-flex">
      <nav class="admin-sidebar-nav">
        {% for item in site.adminNav %}
          <a href="javascript:void(0)" data-nav-section="{{ item.section }}" onclick="show('{{ item.section }}')">
            <i class="bi {{ item.icon }}"></i> {{ item.label }}
          </a>
        {% endfor %}
      </nav>
      <hr>
      <nav class="admin-sidebar-nav">
        <a href="/" target="_blank" rel="noopener"><i class="bi bi-shop"></i> Visit Store</a>
        <a href="javascript:void(0)" data-nav-section="help" onclick="show('help')"><i class="bi bi-question-circle"></i> Help</a>
        <a href="javascript:void(0)" onclick="logout()"><i class="bi bi-box-arrow-right"></i> Logout</a>
      </nav>
    </aside>

    <!-- Mobile/tablet offcanvas sidebar -->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="adminSidebarOffcanvas">
      <div class="offcanvas-header">
        <span class="brand"><span class="brand-dot"></span> {{ site.siteName }}</span>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        <nav class="offcanvas-nav">
          {% for item in site.adminNav %}
            <a href="javascript:void(0)" data-nav-section="{{ item.section }}" data-bs-dismiss="offcanvas" onclick="show('{{ item.section }}')">
              <i class="bi {{ item.icon }}"></i> {{ item.label }}
            </a>
          {% endfor %}
        </nav>
        <hr>
        <nav class="offcanvas-nav">
          <a href="/" target="_blank" rel="noopener"><i class="bi bi-shop"></i> Visit Store</a>
          <a href="javascript:void(0)" data-nav-section="help" data-bs-dismiss="offcanvas" onclick="show('help')"><i class="bi bi-question-circle"></i> Help</a>
          <a href="javascript:void(0)" data-bs-dismiss="offcanvas" onclick="logout()"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </nav>
      </div>
    </div>

    <main class="admin-content">
      {{ content | safe }}
    </main>
  </div>

  <!-- Footer mobile navbar - admin only, hidden on desktop -->
  <div class="mobile-nav d-md-none fixed-bottom">
    <div class="d-flex text-center">
      <a class="flex-fill" data-nav-section="dashboard" onclick="show('dashboard')"><i class="bi bi-speedometer2"></i><br>Home</a>
      <a class="flex-fill" data-nav-section="products" onclick="show('products')"><i class="bi bi-box-seam"></i><br>Products</a>
      <a class="flex-fill" data-nav-section="orders" onclick="show('orders')"><i class="bi bi-receipt"></i><br>Orders</a>
      <a class="flex-fill" data-nav-section="settings" onclick="show('settings')"><i class="bi bi-gear"></i><br>Settings</a>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    async function logout() {
      await fetch("/api/admin-logout", { method: "POST" });
      window.location.href = "/admin-login/";
    }

    // SPA-style section switching - shared across sidebar, offcanvas, and mobile bottom nav
    function show(section) {
      document.querySelectorAll(".admin-section").forEach(el => el.style.display = "none");
      const target = document.getElementById("section-" + section);
      if (target) target.style.display = "block";

      document.querySelectorAll("[data-nav-section]").forEach(el => {
        el.classList.toggle("active", el.dataset.navSection === section);
      });

      if (section === "dashboard" && window.loadDashboard) window.loadDashboard();
      window.scrollTo(0, 0);
    }

    document.addEventListener("DOMContentLoaded", () => show("dashboard"));
  </script>
</body>
</html>
