---
title: Catalog
layout: base.njk
---
<h1>Our Products</h1>
<p><a href="/cart/">View Cart (<span id="cart-count">0</span>)</a></p>

<div id="catalog">Loading products...</div>

<style>
  #catalog { display: flex; flex-wrap: wrap; gap: 16px; }
  .card { border: 1px solid #ddd; border-radius: 8px; padding: 12px; width: 220px; }
  .card img { width: 100%; border-radius: 6px; }
  .card h3 { font-size: 16px; margin: 8px 0 4px; }
  .card select { width: 100%; margin-top: 6px; }
</style>

<script>
  function getCart() {
    return JSON.parse(localStorage.getItem("cart") || "[]");
  }
  function saveCart(cart) {
    localStorage.setItem("cart", JSON.stringify(cart));
    updateCartCount();
  }
  function updateCartCount() {
    const cart = getCart();
    const count = cart.reduce((sum, i) => sum + i.qty, 0);
    document.getElementById("cart-count").textContent = count;
  }
  function addToCart(id, name, photo, size, price) {
    const cart = getCart();
    const existing = cart.find(i => i.id === id && i.size === size);
    if (existing) {
      existing.qty += 1;
    } else {
      cart.push({ id, name, photo, size, price, qty: 1 });
    }
    saveCart(cart);
    alert(name + " (" + size + ") added to cart");
  }

  async function loadCatalog() {
    const el = document.getElementById("catalog");
    try {
      const res = await fetch("/api/products");
      const products = await res.json();

      if (!Array.isArray(products) || products.length === 0) {
        el.innerHTML = "<p>No products yet.</p>";
        return;
      }

      el.innerHTML = products.map(p => {
        const sizeOptions = Object.entries(p.sizes)
          .map(([size, price]) => `<option value="${size}" data-price="${price}">${size} - ₹${price}</option>`)
          .join("");

        return `
          <div class="card">
            <img src="${p.photo}" alt="${p.name}">
            <h3>${p.name}</h3>
            <select id="size-${p.id}">${sizeOptions}</select>
            <button onclick="addFromCard(${p.id}, '${p.name.replace(/'/g, "\\'")}', '${p.photo}')">Add to cart</button>
          </div>
        `;
      }).join("");

    } catch (err) {
      el.innerHTML = "<p>Could not load products. Check console.</p>";
      console.error(err);
    }
  }

  function addFromCard(id, name, photo) {
    const select = document.getElementById("size-" + id);
    const size = select.value;
    const price = Number(select.selectedOptions[0].dataset.price);
    addToCart(id, name, photo, size, price);
  }

  updateCartCount();
  loadCatalog();
</script>
