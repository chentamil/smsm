---
title: Track Order
layout: base.njk
---
<h1>Track Your Order</h1>

<form id="track-form">
  <input type="text" id="order-id-input" placeholder="Enter Order ID" required>
  <button type="submit">Track</button>
</form>

<div id="track-result"></div>

<script>
  document.getElementById("track-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const orderId = document.getElementById("order-id-input").value.trim();
    const resultEl = document.getElementById("track-result");
    resultEl.textContent = "Looking up order...";

    try {
      const res = await fetch("/api/track?order_id=" + encodeURIComponent(orderId));
      const order = await res.json();

      if (!order) {
        resultEl.innerHTML = "<p>No order found with that ID.</p>";
        return;
      }

      resultEl.innerHTML = `
        <h3>Order #${order.order_id}</h3>
        <p>Status: <b>${order.status}</b></p>
        <p>Amount: ₹${order.amount}</p>
        <p>Placed: ${new Date(order.date).toLocaleString()}</p>
        <ul>${order.items.map(i => `<li>${i.name} (${i.size}) x ${i.qty}</li>`).join("")}</ul>
      `;
    } catch (err) {
      resultEl.textContent = "Error looking up order.";
      console.error(err);
    }
  });
</script>
