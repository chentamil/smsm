---
title: Track Order
layout: base.njk
---
<h1>Track Your Order</h1>

<form id="track-form" class="surface-card" style="display:flex; gap: var(--space-2);">
  <input type="text" class="form-control" id="order-id-input" placeholder="Enter Order ID" required>
  <button type="submit" class="btn btn-primary" style="white-space:nowrap;">Track</button>
</form>

<div id="track-result" style="margin-top: var(--space-4);"></div>

<script>
  document.getElementById("track-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const orderId = document.getElementById("order-id-input").value.trim();
    const resultEl = document.getElementById("track-result");
    resultEl.innerHTML = `<div class="alert alert-info">Looking up order...</div>`;

    try {
      const res = await fetch("/api/track?order_id=" + encodeURIComponent(orderId));
      const order = await res.json();

      if (!order) {
        resultEl.innerHTML = `<div class="alert alert-warning">No order found with that ID.</div>`;
        return;
      }

      resultEl.innerHTML = `
        <div class="surface-card">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <h3 style="margin:0;">Order #${order.order_id}</h3>
            <span class="badge" data-status="${order.status}">${order.status}</span>
          </div>
          <p style="margin: var(--space-2) 0 0;">Amount: <strong>₹${order.amount}</strong></p>
          <p style="margin:0;">Placed: ${new Date(order.date).toLocaleString()}</p>
          <div class="stack-sm" style="margin-top: var(--space-3);">
            ${order.items.map(i => `
              <div style="display:flex; justify-content:space-between; font-size:14px;">
                <span>${i.name} (${i.size}) x ${i.qty}</span>
              </div>
            `).join("")}
          </div>
        </div>
      `;
    } catch (err) {
      resultEl.innerHTML = `<div class="alert alert-danger">Error looking up order.</div>`;
      console.error(err);
    }
  });
</script>
