---
title: Admin
layout: base.njk
---
<h1>Admin Dashboard</h1>
<p><button onclick="logout()">Logout</button></p>
<script>
  async function logout() {
    await fetch("/api/admin-logout", { method: "POST" });
    window.location.href = "/admin-login/";
  }
</script>

<h2>Add Product</h2>
<form id="add-form">
  <div><input type="text" id="p-name" placeholder="Product name" required></div>
  <div><input type="text" id="p-photo" placeholder="Photo URL" required></div>
  <div><input type="text" id="p-sizes" placeholder='Sizes as JSON e.g. {"S":100,"M":120}' required></div>
  <button type="submit">Add Product</button>
</form>
<p id="add-result"></p>

<h2>Products</h2>
<div id="product-list">Loading...</div>

<h2>Orders</h2>
<div id="order-list">Loading...</div>

<style>
  form div { margin-bottom: 8px; }
  form input { padding: 6px; width: 320px; }
  table { border-collapse: collapse; width: 100%; margin-top: 10px; }
  th, td { border: 1px solid #ddd; padding: 6px 10px; text-align: left; font-size: 14px; }
</style>

<script>
  async function loadProducts() {
    const res = await fetch("/api/admin/products");
    const products = await res.json();
    const el = document.getElementById("product-list");

    if (!Array.isArray(products) || products.length === 0) {
      el.innerHTML = "<p>No products yet.</p>";
      return;
    }

    el.innerHTML = `
      <table>
        <tr><th>Name</th><th>Photo</th><th>Sizes</th><th>Actions</th></tr>
        ${products.map(p => `
          <tr>
            <td>${p.name}</td>
            <td>${p.photo}</td>
            <td>${JSON.stringify(p.sizes)}</td>
            <td><button onclick="deleteProduct(${p.id})">Delete</button></td>
          </tr>
        `).join("")}
      </table>
    `;
  }

  async function deleteProduct(id) {
    if (!confirm("Delete this product?")) return;
    await fetch("/api/admin/products", {
      method: "DELETE",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id })
    });
    loadProducts();
  }

  document.getElementById("add-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const resultEl = document.getElementById("add-result");

    let sizes;
    try {
      sizes = JSON.parse(document.getElementById("p-sizes").value);
    } catch {
      resultEl.textContent = "Sizes must be valid JSON, e.g. {\"S\":100,\"M\":120}";
      return;
    }

    const res = await fetch("/api/admin/products", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        name: document.getElementById("p-name").value,
        photo: document.getElementById("p-photo").value,
        sizes
      })
    });
    const data = await res.json();

    if (data.success) {
      resultEl.textContent = "Product added.";
      document.getElementById("add-form").reset();
      loadProducts();
    } else {
      resultEl.textContent = "Error: " + (data.error || "unknown");
    }
  });

  async function loadOrders() {
    const res = await fetch("/api/admin/orders");
    const orders = await res.json();
    const el = document.getElementById("order-list");

    if (!Array.isArray(orders) || orders.length === 0) {
      el.innerHTML = "<p>No orders yet.</p>";
      return;
    }

    const statuses = ["UNPAID", "CONFIRMED", "SHIPPED", "DELIVERED", "CANCELLED"];

    el.innerHTML = `
      <table>
        <tr><th>Order ID</th><th>Customer</th><th>Amount</th><th>Status</th><th>Date</th></tr>
        ${orders.map(o => `
          <tr>
            <td>${o.order_id}</td>
            <td>${o.customer.name}<br>${o.customer.email}</td>
            <td>₹${o.amount}</td>
            <td>
              <select onchange="updateStatus('${o.order_id}', this.value)">
                ${statuses.map(s => `<option value="${s}" ${s === o.status ? "selected" : ""}>${s}</option>`).join("")}
              </select>
            </td>
            <td>${new Date(o.date).toLocaleString()}</td>
          </tr>
        `).join("")}
      </table>
    `;
  }

  async function updateStatus(orderId, status) {
    await fetch("/api/admin/orders", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ order_id: orderId, status })
    });
  }

  loadProducts();
  loadOrders();
</script>
